{
  "name": "the-seven",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @the-seven/web dev",
    "build": "pnpm --filter @the-seven/web build",
    "start": "pnpm --filter @the-seven/web start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "tsc --pretty false --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "batch": "node --env-file=.env --import tsx apps/cli/src/index.ts",
    "db:bootstrap:check": "node --env-file=.env --import tsx tools/db-bootstrap-check.ts"
  },
  "devDependencies": {
    "@the-seven/config": "workspace:*",
    "@the-seven/db": "workspace:*",
    "@biomejs/biome": "2.4.8",
    "@playwright/test": "1.58.2",
    "@types/node": "25.5.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
