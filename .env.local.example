# Core
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/the_seven
SEVEN_JOB_CREDENTIAL_SECRET=replace-with-a-local-random-secret
SEVEN_PUBLIC_ORIGIN=http://localhost:3000
