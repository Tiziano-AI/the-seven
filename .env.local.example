# Demo is disabled in the minimal local profile.
SEVEN_DEMO_ENABLED=0
SEVEN_DEMO_OPENROUTER_KEY=
SEVEN_DEMO_RESEND_API_KEY=
SEVEN_DEMO_EMAIL_FROM=

# Local tools
SEVEN_BASE_URL=http://127.0.0.1:3000
