# On this Mac, add these as THE_SEVEN__... keys in /Users/tiziano/.secrets/ALL.env
# and run `tiz-home --json secrets sync --apply` to regenerate .env.local.
# In other environments, provide the unprefixed names to the app runtime.
SEVEN_DEMO_ENABLED=1
SEVEN_PUBLIC_ORIGIN=https://theseven.ai
SEVEN_BYOK_KEY=sk-or-live-byok-key
SEVEN_DEMO_OPENROUTER_KEY=sk-or-live-demo-key
SEVEN_DEMO_RESEND_API_KEY=re_live_resend_key
SEVEN_DEMO_EMAIL_FROM=demo@verified-domain.example
SEVEN_DEMO_TEST_EMAIL=inbound-test@your-inbound-domain.example

# Optional when live proof targets an already-running external app.
# `pnpm local:live` projects a free loopback SEVEN_BASE_URL automatically.
SEVEN_BASE_URL=
