# Server environment (development | production | test)
# NODE_ENV="development"

# Server port (default: 3000; auto-increments if port is occupied)
# PORT="3000"

# SQLite database file path (relative paths resolve from repo root)
SEVEN_DB_PATH="data/the-seven.db"

# Optional: outbound app identity headers for OpenRouter (recommended in production)
SEVEN_PUBLIC_ORIGIN="http://localhost:3000"
SEVEN_APP_NAME="The Seven"

# Development-only: skip OpenRouter API key validation on the client onboarding flow.
# - Only honored when NODE_ENV="development"
# - Useful for local UI testing without a real key (provider calls will still fail with an invalid key)
# SEVEN_DEV_DISABLE_OPENROUTER_KEY_VALIDATION="1"

# Prompt posture:
# - We do not truncate, compress, or locally "budget" prompts.
# - OpenRouter can apply message transforms (e.g. middle-out compression) by default for some models.
#   This service disables transforms on every request (`transforms: []`) so oversized prompts fail loudly.
